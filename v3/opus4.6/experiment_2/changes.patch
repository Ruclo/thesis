+"""
+VNC Console Screenshot Tests
+
+STP Reference: stps/2.md
+Jira: CNV-61271 / CNV-60117
+
+Tests verifying that the VM screenshot endpoint uses libvirt's virDomainScreenshot
+API instead of VNC, allowing screenshots and VNC connections to coexist without
+interference.
+"""
+
+import logging
+from pathlib import Path
+
+import pytest
+
+from tests.virt.cluster.vnc_screenshot.utils import PNG_HEADER, capture_vm_screenshot
+from utilities.vnc_utils import VNCConnection
+
+LOGGER = logging.getLogger(__name__)
+
+SCREENSHOT_REPEAT_COUNT = 5
+
+
+@pytest.mark.tier3
+class TestVncScreenshot:
+    """Tests for VM screenshot functionality via libvirt API."""
+
+    def test_screenshot_without_active_vnc_connection(self, tmp_path, vm_for_vnc_screenshot):
+        """
+        Test that a VM screenshot can be captured without any active VNC connection.
+
+        Steps:
+            1. Capture a screenshot of the VM using virtctl vnc screenshot
+
+        Expected:
+            - Screenshot command succeeds and produces a file
+        """
+        screenshot_path = str(tmp_path / f"{vm_for_vnc_screenshot.name}.png")
+        LOGGER.info(f"Capturing screenshot of VM {vm_for_vnc_screenshot.name} without active VNC connection")
+        capture_vm_screenshot(
+            vm_name=vm_for_vnc_screenshot.name,
+            vm_namespace=vm_for_vnc_screenshot.namespace,
+            output_path=screenshot_path,
+        )
+        assert Path(screenshot_path).exists(), f"Screenshot file was not created at {screenshot_path}"
+
+    def test_screenshot_returns_valid_image(self, tmp_path, vm_for_vnc_screenshot):
+        """
+        Test that the captured screenshot is a valid PNG image.
+
+        Steps:
+            1. Capture a screenshot of the VM using virtctl vnc screenshot
+            2. Read the output file and check its header bytes
+
+        Expected:
+            - Screenshot file has a valid PNG header
+        """
+        screenshot_path = str(tmp_path / f"{vm_for_vnc_screenshot.name}.png")
+        LOGGER.info(f"Capturing screenshot for PNG validation from VM {vm_for_vnc_screenshot.name}")
+        capture_vm_screenshot(
+            vm_name=vm_for_vnc_screenshot.name,
+            vm_namespace=vm_for_vnc_screenshot.namespace,
+            output_path=screenshot_path,
+        )
+        with open(screenshot_path, "rb") as screenshot_file:
+            header = screenshot_file.read(len(PNG_HEADER))
+        assert header == PNG_HEADER, f"Screenshot file does not have valid PNG header: got {header!r}"
+
+    def test_vnc_remains_connected_during_screenshot(self, tmp_path, vm_for_vnc_screenshot):
+        """
+        Test that an active VNC connection is not disrupted when a screenshot
+        is captured concurrently.
+
+        Steps:
+            1. Establish a VNC connection to the VM
+            2. Capture a screenshot of the VM while VNC is connected
+            3. Verify the VNC connection is still active
+
+        Expected:
+            - VNC connection is still active after screenshot capture
+        """
+        screenshot_path = str(tmp_path / f"{vm_for_vnc_screenshot.name}.png")
+        with VNCConnection(vm=vm_for_vnc_screenshot) as vnc_child:
+            assert vnc_child is not None, "VNC connection failed to establish"
+            LOGGER.info(f"VNC connection established to VM {vm_for_vnc_screenshot.name}")
+            capture_vm_screenshot(
+                vm_name=vm_for_vnc_screenshot.name,
+                vm_namespace=vm_for_vnc_screenshot.namespace,
+                output_path=screenshot_path,
+            )
+            LOGGER.info("Screenshot captured, verifying VNC connection is still active")
+            assert vnc_child.isalive(), "VNC connection was disconnected during screenshot capture"
+
+    def test_vnc_remains_connected_during_repeated_screenshots(self, tmp_path, vm_for_vnc_screenshot):
+        """
+        Test that an active VNC connection remains stable when multiple
+        screenshots are captured in succession.
+
+        Steps:
+            1. Establish a VNC connection to the VM
+            2. Capture 5 consecutive screenshots of the VM
+            3. Verify the VNC connection is still active after all screenshots
+
+        Expected:
+            - VNC connection is still active after all screenshot captures
+        """
+        with VNCConnection(vm=vm_for_vnc_screenshot) as vnc_child:
+            assert vnc_child is not None, "VNC connection failed to establish"
+            LOGGER.info(f"VNC connection established to VM {vm_for_vnc_screenshot.name}")
+            for screenshot_index in range(SCREENSHOT_REPEAT_COUNT):
+                screenshot_path = str(tmp_path / f"{vm_for_vnc_screenshot.name}-{screenshot_index}.png")
+                LOGGER.info(f"Capturing screenshot {screenshot_index + 1}/{SCREENSHOT_REPEAT_COUNT}")
+                capture_vm_screenshot(
+                    vm_name=vm_for_vnc_screenshot.name,
+                    vm_namespace=vm_for_vnc_screenshot.namespace,
+                    output_path=screenshot_path,
+                )
+            LOGGER.info("All screenshots captured, verifying VNC connection is still active")
+            assert vnc_child.isalive(), (
+                f"VNC connection was disconnected after {SCREENSHOT_REPEAT_COUNT} screenshot captures"
+            )
+
+
+@pytest.mark.tier3
+class TestVncScreenshotGuestCompatibility:
+    """Tests for VM screenshot functionality across different guest operating systems."""
+
+    def test_screenshot_succeeds_for_guest_os(self, tmp_path, vm_for_guest_compatibility):
+        """
+        Test that a screenshot can be captured for a VM running the given guest OS.
+
+        Steps:
+            1. Capture a screenshot of the VM using virtctl vnc screenshot
+
+        Expected:
+            - Screenshot command succeeds and produces a valid image file
+        """
+        screenshot_path = str(tmp_path / f"{vm_for_guest_compatibility.name}.png")
+        LOGGER.info(f"Capturing screenshot of VM {vm_for_guest_compatibility.name}")
+        capture_vm_screenshot(
+            vm_name=vm_for_guest_compatibility.name,
+            vm_namespace=vm_for_guest_compatibility.namespace,
+            output_path=screenshot_path,
+        )
+        screenshot_file_path = Path(screenshot_path)
+        assert screenshot_file_path.exists(), f"Screenshot file was not created at {screenshot_path}"
+        with open(screenshot_path, "rb") as screenshot_file:
+            header = screenshot_file.read(len(PNG_HEADER))
+        assert header == PNG_HEADER, f"Screenshot file does not have valid PNG header: got {header!r}"
