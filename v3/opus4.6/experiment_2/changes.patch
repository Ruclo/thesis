+"""VNC screenshot test utilities."""
+
+import shlex
+
+from utilities.infra import run_virtctl_command
+
+PNG_HEADER = b"\x89PNG\r\n\x1a\n"
+
+
+def capture_vm_screenshot(vm_name: str, vm_namespace: str, output_path: str) -> None:
+    """Capture a VM screenshot using the virtctl vnc screenshot command.
+
+    Args:
+        vm_name: Name of the virtual machine.
+        vm_namespace: Namespace of the virtual machine.
+        output_path: File path where the screenshot PNG will be saved.
+
+    Raises:
+        CalledProcessError: If the virtctl screenshot command fails.
+    """
+    run_virtctl_command(
+        command=shlex.split(f"vnc screenshot {vm_name} -f {output_path}"),
+        namespace=vm_namespace,
+        check=True,
+        verify_stderr=False,
+    )
