+import logging
+import shlex
+
+import pytest
+from ocp_resources.cluster_role import ClusterRole
+from ocp_resources.role_binding import RoleBinding
+from ocp_resources.virtual_machine import VirtualMachine
+from pyhelper_utils.shell import run_ssh_commands
+
+from utilities.constants import UNPRIVILEGED_USER
+from utilities.virt import (
+    VirtualMachineForTests,
+    fedora_vm_body,
+    running_vm,
+    wait_for_running_vm,
+)
+
+LOGGER = logging.getLogger(__name__)
+
+
+def get_boot_time(vm: VirtualMachineForTests) -> str:
+    """Get the guest boot time as a string.
+
+    Returns:
+        str: Boot time string from `uptime --since`, e.g. "2026-02-22 10:23:45".
+    """
+    return run_ssh_commands(
+        host=vm.ssh_exec,
+        commands=[shlex.split("uptime --since")],
+    )[0].strip()
+
+
+@pytest.fixture(scope="class")
+def vmi_state_before_reset(vm_for_test: VirtualMachineForTests) -> dict[str, str]:
+    """Capture VMI state before hard reset: pod name, VMI UID, boot time."""
+    LOGGER.info(f"Capturing VMI state before reset for VM {vm_for_test.name}")
+    virt_launcher_pod = vm_for_test.vmi.virt_launcher_pod
+    assert virt_launcher_pod, "virt-launcher pod not found for VMI"
+    pod_name = virt_launcher_pod.name
+    vmi_uid = vm_for_test.vmi.instance.metadata.uid
+    boot_time = get_boot_time(vm=vm_for_test)
+    LOGGER.info(f"Pre-reset state: pod={pod_name}, uid={vmi_uid}, boot_time={boot_time}")
+    return {
+        "pod_name": pod_name,
+        "vmi_uid": vmi_uid,
+        "boot_time": boot_time,
+    }
+
+
+@pytest.fixture(scope="class")
+def vm_after_hard_reset(
+    vm_for_test: VirtualMachineForTests,
+    vmi_state_before_reset: dict[str, str],
+) -> None:
+    """Perform hard reset on VMI and wait for VM to become running and SSH accessible."""
+    LOGGER.info(f"Performing hard reset on VMI {vm_for_test.name}")
+    vm_for_test.vmi.reset()
+    LOGGER.info("Hard reset issued, waiting for VM to become running and SSH accessible")
+    wait_for_running_vm(vm=vm_for_test)
+    LOGGER.info(f"VM {vm_for_test.name} is running after hard reset")
+
+
+@pytest.fixture()
+def stopped_vm(namespace, unprivileged_client):
+    """VM created with Halted run strategy (no VMI exists)."""
+    vm_name = "vm-stopped-for-reset-test"
+    with VirtualMachineForTests(
+        client=unprivileged_client,
+        name=vm_name,
+        body=fedora_vm_body(name=vm_name),
+        namespace=namespace.name,
+        run_strategy=VirtualMachine.RunStrategy.HALTED,
+    ) as vm:
+        LOGGER.info(f"Created stopped VM {vm_name} (no VMI)")
+        yield vm
+
+
+@pytest.fixture()
+def paused_vm(namespace, unprivileged_client):
+    """Running VM with VMI in paused state."""
+    vm_name = "vm-paused-for-reset-test"
+    with VirtualMachineForTests(
+        client=unprivileged_client,
+        name=vm_name,
+        body=fedora_vm_body(name=vm_name),
+        namespace=namespace.name,
+    ) as vm:
+        running_vm(vm=vm)
+        LOGGER.info(f"Pausing VMI for VM {vm_name}")
+        vm.vmi.pause(wait=True)
+        LOGGER.info(f"VMI for VM {vm_name} is paused")
+        yield vm
+
+
+@pytest.fixture()
+def edit_cluster_role(admin_client):
+    """The built-in 'edit' ClusterRole."""
+    return ClusterRole(name="edit", client=admin_client, ensure_exists=True)
+
+
+@pytest.fixture()
+def edit_role_binding_for_unprivileged_user(admin_client, namespace, edit_cluster_role):
+    """RoleBinding granting UNPRIVILEGED_USER the edit ClusterRole in test namespace."""
+    with RoleBinding(
+        name="role-bind-edit-for-reset-test",
+        namespace=namespace.name,
+        client=admin_client,
+        subjects_kind="User",
+        subjects_name=UNPRIVILEGED_USER,
+        subjects_namespace=namespace.name,
+        role_ref_kind=edit_cluster_role.kind,
+        role_ref_name=edit_cluster_role.name,
+    ) as role_binding:
+        LOGGER.info(f"Created edit RoleBinding for {UNPRIVILEGED_USER} in {namespace.name}")
+        yield role_binding
+
+
+@pytest.fixture()
+def vm_for_rbac_reset_test(namespace, unprivileged_client, edit_role_binding_for_unprivileged_user):
+    """Running VM created by unprivileged user with edit role for RBAC reset test."""
+    vm_name = "vm-for-rbac-reset-test"
+    with VirtualMachineForTests(
+        client=unprivileged_client,
+        name=vm_name,
+        body=fedora_vm_body(name=vm_name),
+        namespace=namespace.name,
+    ) as vm:
+        running_vm(vm=vm)
+        yield vm
