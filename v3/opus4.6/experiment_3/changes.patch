+"""
+VMI Reset via virtctl Tests
+
+STP Reference: https://issues.redhat.com/browse/VIRTSTRAT-357
+
+This module contains tests for the VMI hard reset via the virtctl CLI command.
+"""
+
+import logging
+
+import pytest
+
+from utilities.infra import run_virtctl_command
+from utilities.virt import (
+    VirtualMachineForTests,
+    fedora_vm_body,
+    running_vm,
+    wait_for_running_vm,
+)
+
+LOGGER = logging.getLogger(__name__)
+
+
+@pytest.fixture()
+def vm_for_virtctl_reset(namespace, unprivileged_client):
+    """Running Fedora VM for virtctl reset test."""
+    vm_name = "vm-for-virtctl-reset-test"
+    with VirtualMachineForTests(
+        client=unprivileged_client,
+        name=vm_name,
+        body=fedora_vm_body(name=vm_name),
+        namespace=namespace.name,
+    ) as vm:
+        running_vm(vm=vm)
+        yield vm
+
+
+@pytest.mark.polarion("CNV-12377")
+def test_reset_running_vmi_via_virtctl(vm_for_virtctl_reset):
+    """Test that a running VMI can be reset using the virtctl reset command.
+
+    Steps:
+        1. Execute virtctl reset command targeting the running VMI
+        2. Wait for VMI to become running and SSH accessible
+
+    Expected:
+        - VMI is "Running" and SSH accessible after virtctl reset
+    """
+    LOGGER.info(f"Executing virtctl reset on VMI {vm_for_virtctl_reset.name}")
+    result, output, error = run_virtctl_command(
+        command=["reset", vm_for_virtctl_reset.name],
+        namespace=vm_for_virtctl_reset.namespace,
+        check=True,
+    )
+    LOGGER.info(f"virtctl reset result: success={result}, output={output}")
+    wait_for_running_vm(vm=vm_for_virtctl_reset)
+    LOGGER.info(f"VM {vm_for_virtctl_reset.name} is running and SSH accessible after virtctl reset")
+    assert vm_for_virtctl_reset.vmi.status == vm_for_virtctl_reset.vmi.Status.RUNNING, (
+        f"VMI is not running after virtctl reset, status: {vm_for_virtctl_reset.vmi.status}"
+    )
