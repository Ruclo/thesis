+"""
+VMI Hard Reset API Tests
+
+STP Reference: https://issues.redhat.com/browse/VIRTSTRAT-357
+
+This module contains end-to-end tests for the VMI hard reset subresource API,
+verifying that reset preserves pod assignment and VMI identity while causing
+an actual guest reboot.
+"""
+
+import logging
+
+import pytest
+
+from tests.virt.node.hard_reset.conftest import get_boot_time
+
+LOGGER = logging.getLogger(__name__)
+
+
+@pytest.mark.parametrize("vm_for_test", [pytest.param("vm-for-hard-reset-test")], indirect=True)
+class TestVMIHardResetAPI:
+    """Tests for VMI hard reset via the subresource API endpoint."""
+
+    @pytest.mark.polarion("CNV-12374")
+    @pytest.mark.usefixtures("vm_after_hard_reset")
+    def test_pod_preserved_after_reset(self, vm_for_test, vmi_state_before_reset):
+        """Test that the VMI pod is not rescheduled after a hard reset.
+
+        Steps:
+            1. Compare the pod name before and after reset
+
+        Expected:
+            - Pod name before reset equals pod name after reset
+        """
+        pod_name_after_reset = vm_for_test.vmi.virt_launcher_pod.name
+        LOGGER.info(f"Pod name after reset: {pod_name_after_reset}")
+        assert vmi_state_before_reset["pod_name"] == pod_name_after_reset, (
+            f"Pod was rescheduled after reset: before={vmi_state_before_reset['pod_name']}, after={pod_name_after_reset}"
+        )
+
+    @pytest.mark.polarion("CNV-12375")
+    @pytest.mark.usefixtures("vm_after_hard_reset")
+    def test_vmi_uid_unchanged_after_reset(self, vm_for_test, vmi_state_before_reset):
+        """Test that the VMI UID remains the same after a hard reset.
+
+        Steps:
+            1. Compare the VMI UID before and after reset
+
+        Expected:
+            - VMI UID before reset equals VMI UID after reset
+        """
+        vmi_uid_after_reset = vm_for_test.vmi.instance.metadata.uid
+        LOGGER.info(f"VMI UID after reset: {vmi_uid_after_reset}")
+        assert vmi_state_before_reset["vmi_uid"] == vmi_uid_after_reset, (
+            f"VMI UID changed after reset: before={vmi_state_before_reset['vmi_uid']}, after={vmi_uid_after_reset}"
