+"""
+VMI Reset RBAC Tests
+
+STP Reference: https://issues.redhat.com/browse/VIRTSTRAT-357
+
+This module contains tests verifying that RBAC permissions are properly
+enforced for the VMI reset subresource operation.
+"""
+
+import logging
+
+import pytest
+
+from utilities.virt import wait_for_running_vm
+
+LOGGER = logging.getLogger(__name__)
+
+
+@pytest.mark.polarion("CNV-12381")
+@pytest.mark.usefixtures("edit_role_binding_for_unprivileged_user")
+def test_edit_role_user_can_reset_vmi(vm_for_rbac_reset_test):
+    """Test that a user with the edit ClusterRole can reset a running VMI.
+
+    Steps:
+        1. As the edit-role user, perform a reset on the running VMI via subresource API
+
+    Expected:
+        - Reset operation succeeds without authorization error
+    """
+    LOGGER.info(f"Performing reset as unprivileged user on VM {vm_for_rbac_reset_test.name}")
+    vm_for_rbac_reset_test.vmi.reset()
+    LOGGER.info("Reset succeeded, waiting for VM to become running")
+    wait_for_running_vm(vm=vm_for_rbac_reset_test)
+    LOGGER.info(f"VM {vm_for_rbac_reset_test.name} is running after RBAC reset test")
