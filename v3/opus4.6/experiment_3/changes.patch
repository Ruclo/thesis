+"""
+VMI Reset Negative and Edge Case Tests
+
+STP Reference: https://issues.redhat.com/browse/VIRTSTRAT-357
+
+This module contains negative tests verifying that VMI reset fails gracefully
+on invalid targets (stopped VMIs, non-existent VMIs), and an edge case test
+verifying that reset succeeds on a paused VMI.
+"""
+
+import logging
+
+import pytest
+from kubernetes.client.rest import ApiException
+from ocp_resources.virtual_machine_instance import VirtualMachineInstance
+
+LOGGER = logging.getLogger(__name__)
+
+
+class TestVMIResetNegative:
+    """Negative tests for VMI reset error handling."""
+
+    @pytest.mark.polarion("CNV-12378")
+    def test_reset_fails_on_stopped_vmi(self, stopped_vm):
+        """[NEGATIVE] Test that resetting a stopped VMI returns an appropriate error.
+
+        Steps:
+            1. Attempt to reset the stopped VMI via subresource API
+
+        Expected:
+            - Reset operation fails with an error indicating VMI is not found
+        """
+        LOGGER.info(f"Attempting to reset stopped VM {stopped_vm.name} (no VMI exists)")
+        with pytest.raises(ApiException):
+            stopped_vm.vmi.reset()
+
+    @pytest.mark.polarion("CNV-12379")
+    def test_reset_fails_on_nonexistent_vmi(self, namespace, admin_client):
+        """[NEGATIVE] Test that resetting a non-existent VMI returns a not-found error.
+
+        Steps:
+            1. Attempt to reset a VMI name that does not exist in the namespace
+
+        Expected:
+            - Reset operation fails with a not-found error
+        """
+        nonexistent_vmi_name = "nonexistent-vmi-for-reset-test"
+        LOGGER.info(f"Attempting to reset non-existent VMI {nonexistent_vmi_name}")
+        nonexistent_vmi = VirtualMachineInstance(
+            client=admin_client,
+            name=nonexistent_vmi_name,
+            namespace=namespace.name,
+        )
+        with pytest.raises(ApiException):
+            nonexistent_vmi.reset()
+
+    @pytest.mark.polarion("CNV-12380")
+    def test_reset_succeeds_on_paused_vmi(self, paused_vm):
+        """Test that resetting a paused VMI is accepted by the API without error.
+
+        The VMI remains paused after reset; the reset signal is queued and
+        will take effect when the VMI is unpaused.
+
+        Steps:
+            1. Reset the paused VMI via subresource API
+
+        Expected:
+            - Reset operation succeeds without raising an error
+        """
+        LOGGER.info(f"Resetting paused VM {paused_vm.name}")
+        paused_vm.vmi.reset()
+        LOGGER.info(f"Reset API call succeeded on paused VMI {paused_vm.name}")
