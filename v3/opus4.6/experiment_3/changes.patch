+
+    @pytest.mark.polarion("CNV-12376")
+    @pytest.mark.usefixtures("vm_after_hard_reset")
+    def test_boot_time_changes_after_reset(self, vm_for_test, vmi_state_before_reset):
+        """Test that the guest boot time changes after a hard reset, confirming an actual reboot.
