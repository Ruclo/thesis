+"""
+CPU Hotplug MaxSockets Limit Tests
+
+STP Reference: stps/6.md
+Jira: https://issues.redhat.com/browse/CNV-61263
+Bug Fix: https://issues.redhat.com/browse/CNV-57352
+PR: https://github.com/kubevirt/kubevirt/pull/14511
+
+This module contains tests verifying that MaxSockets is properly limited
+based on the maximum allowed vCPUs (512 ceiling) when CPU hotplug is enabled.
+The fix caps MaxSockets so that sockets x cores x threads does not exceed
+the defaultMaxSocketsLimit (128 x hotplug ratio).
+"""
+
+import logging
+
+import pytest
+from kubernetes.dynamic.exceptions import UnprocessibleEntityError
+from ocp_resources.template import Template
+
+from tests.os_params import RHEL_LATEST, RHEL_LATEST_LABELS
+from tests.utils import (
+    clean_up_migration_jobs,
+    hotplug_spec_vm,
+    hotplug_spec_vm_and_verify_hotplug,
+    wait_for_guest_os_cpu_count,
+)
+from utilities.constants import (
+    FOUR_CPU_SOCKETS,
+    FOUR_GI_MEMORY,
+    ONE_CPU_CORE,
+    ONE_CPU_THREAD,
+    SIX_CPU_SOCKETS,
+    TWO_CPU_SOCKETS,
+)
+from utilities.virt import (
+    VirtualMachineForTestsFromTemplate,
+    running_vm,
+)
+
+pytestmark = pytest.mark.rwx_default_storage
+
+LOGGER = logging.getLogger(__name__)
+TESTS_CLASS_NAME = "TestCPUHotplugMaxSocketsLimit"
+MAX_VCPU_LIMIT = 512
+REQUESTED_MAX_SOCKETS = 16
+
+
+@pytest.fixture(scope="class")
+def vm_with_high_max_sockets(
+    request,
+    namespace,
+    unprivileged_client,
+    golden_image_data_volume_template_for_test_scope_class,
+    modern_cpu_for_migration,
+    vmx_disabled_flag,
+):
+    """VM with cpu_max_sockets set above EIGHT_CPU_SOCKETS to verify MaxSockets enforcement."""
+    with VirtualMachineForTestsFromTemplate(
+        name=request.param["vm_name"],
+        labels=Template.generate_template_labels(**request.param["template_labels"]),
+        namespace=namespace.name,
+        client=unprivileged_client,
+        data_volume_template=golden_image_data_volume_template_for_test_scope_class,
+        cpu_max_sockets=REQUESTED_MAX_SOCKETS,
+        cpu_sockets=TWO_CPU_SOCKETS,
+        cpu_threads=ONE_CPU_THREAD,
+        cpu_cores=ONE_CPU_CORE,
+        memory_guest=FOUR_GI_MEMORY,
+        cpu_model=modern_cpu_for_migration,
+        cpu_flags=vmx_disabled_flag,
+    ) as vm:
+        running_vm(vm=vm)
+        yield vm
+
+
+@pytest.fixture()
+def hotplugged_cpu_sockets(request, admin_client, vm_with_high_max_sockets, unprivileged_client):
+    """Applies CPU socket hotplug and cleans up migration jobs after the test."""
+    hotplug_spec_vm_and_verify_hotplug(
+        vm=vm_with_high_max_sockets,
+        client=unprivileged_client,
+        sockets=request.param["sockets"],
+    )
+    yield
+    clean_up_migration_jobs(client=admin_client, vm=vm_with_high_max_sockets)
+
+
+@pytest.mark.parametrize(
+    "golden_image_data_source_for_test_scope_class, vm_with_high_max_sockets",
+    [
+        pytest.param(
+            {"os_dict": RHEL_LATEST},
+            {"template_labels": RHEL_LATEST_LABELS, "vm_name": "rhel-cpu-max-sockets-limit-vm"},
+            id="RHEL-VM",
+            marks=pytest.mark.s390x,
+        ),
+    ],
+    indirect=True,
+)
+class TestCPUHotplugMaxSocketsLimit:
+    # Dependency: establishes VM baseline state; subsequent tests modify VM socket count
+    @pytest.mark.dependency(name=f"{TESTS_CLASS_NAME}::max_sockets_capped")
+    @pytest.mark.polarion("CNV-61263")
+    def test_max_sockets_limited_by_vcpu_ceiling(self, vm_with_high_max_sockets):
+        """
+        Test that MaxSockets is correctly set on VMI and total vCPUs do not exceed the limit.
+
+        Preconditions:
+            - VM created with CPU hotplug enabled and cpu_max_sockets=16
+
+        Steps:
+            1. Inspect the VMI spec to read the effective MaxSockets value
+
+        Expected:
+            - MaxSockets multiplied by cores and threads is less than or equal to 512
+        """
+        vmi_cpu = vm_with_high_max_sockets.vmi.instance.spec.domain.cpu
+        effective_max_sockets = vmi_cpu.maxSockets
+        total_vcpus = effective_max_sockets * ONE_CPU_CORE * ONE_CPU_THREAD
+        LOGGER.info(
+            f"Requested MaxSockets: {REQUESTED_MAX_SOCKETS}, "
+            f"effective MaxSockets: {effective_max_sockets}, "
+            f"total vCPUs: {total_vcpus}"
+        )
+        assert effective_max_sockets <= REQUESTED_MAX_SOCKETS, (
+            f"MaxSockets exceeds requested value: requested {REQUESTED_MAX_SOCKETS}, got {effective_max_sockets}"
+        )
+        assert total_vcpus <= MAX_VCPU_LIMIT, (
+            f"Total vCPUs ({total_vcpus}) exceeds maximum limit ({MAX_VCPU_LIMIT})"
+        )
+
+    # Dependency: hotplug modifies VM socket count; tests 3 and 4 rely on VM being in hotplugged state
+    @pytest.mark.parametrize(
+        "hotplugged_cpu_sockets",
+        [pytest.param({"sockets": FOUR_CPU_SOCKETS})],
+        indirect=True,
+    )
+    @pytest.mark.dependency(
+        name=f"{TESTS_CLASS_NAME}::hotplug_within_limit",
+        depends=[f"{TESTS_CLASS_NAME}::max_sockets_capped"],
+    )
+    @pytest.mark.polarion("CNV-61263")
+    def test_hotplug_cpu_up_to_max_sockets(self, hotplugged_cpu_sockets, vm_with_high_max_sockets):
+        """
+        Test that CPU hotplug succeeds when target sockets are within the MaxSockets limit.
+
+        Steps:
+            1. Hotplug CPU sockets to a value within the MaxSockets limit
+            2. Wait for guest OS to recognize the new CPU count
+
+        Expected:
+            - Guest OS CPU count equals the hotplugged socket value
+        """
+        wait_for_guest_os_cpu_count(vm=vm_with_high_max_sockets, spec_cpu_amount=FOUR_CPU_SOCKETS)
+
+    # Dependency: VM must be in hotplugged state from test 2; this test verifies rejection at limit
+    @pytest.mark.dependency(depends=[f"{TESTS_CLASS_NAME}::hotplug_within_limit"])
+    @pytest.mark.polarion("CNV-61263")
+    def test_hotplug_cpu_beyond_max_sockets_rejected(self, vm_with_high_max_sockets):
+        """
+        [NEGATIVE] Test that CPU hotplug is rejected when target sockets exceed MaxSockets.
+
+        Steps:
+            1. Attempt to hotplug CPU sockets to a value exceeding MaxSockets
+
+        Expected:
+            - UnprocessibleEntityError is raised
+        """
