+# -*- coding: utf-8 -*-
+
+"""
+VM Snapshot Restore with Run Strategy Tests
+
+STP Reference: https://issues.redhat.com/browse/CNV-63819
+
+This module contains tests verifying that snapshot restore operations complete
+successfully across different VM run strategies. Focuses on the CNV-63819 fix
+where restore would get stuck with runStrategy: RerunOnFailure because
+virt-controller immediately tried to start the VM during restore.
+"""
+
+import logging
+
+import pytest
+from ocp_resources.virtual_machine import VirtualMachine
+from ocp_resources.virtual_machine_restore import VirtualMachineRestore
+from timeout_sampler import TimeoutSampler
+
+from utilities.constants import TIMEOUT_5MIN, TIMEOUT_5SEC
+from utilities.virt import running_vm
+
+LOGGER = logging.getLogger(__name__)
+
+pytestmark = pytest.mark.usefixtures(
+    "namespace",
+    "skip_if_no_storage_class_for_snapshot",
+)
+
+
+class TestSnapshotRestoreRerunOnFailure:
+    """
+    Tests for VM snapshot restore with runStrategy: RerunOnFailure.
+
+    Verifies that the snapshot restore operation completes successfully
+    when the VM uses RerunOnFailure run strategy (CNV-63819 fix verification).
+    """
+
+    @pytest.mark.polarion("CNV-63819")
+    def test_restore_completes(self, completed_rerun_on_failure_restore):
+        """
+        Test that snapshot restore completes for VM with RerunOnFailure run strategy.
+
+        Steps:
+            1. Check VirtualMachineRestore resource status
+
+        Expected:
+            - VirtualMachineRestore status is "Complete"
+        """
+        assert completed_rerun_on_failure_restore.instance.status.get("complete"), (
+            f"VirtualMachineRestore {completed_rerun_on_failure_restore.name} "
+            "did not reach Complete status"
+        )
+
+    @pytest.mark.polarion("CNV-63819")
+    def test_vm_starts_after_restore(
+        self,
+        rerun_on_failure_vm,
+        completed_rerun_on_failure_restore,
+    ):
+        """
+        Test that VM can be started manually after snapshot restore completes.
+
+        Steps:
+            1. Start the VM and wait for it to reach Running state
+
+        Expected:
+            - VM is "Running" and SSH accessible
+        """
+        LOGGER.info(f"Starting VM {rerun_on_failure_vm.name} after restore")
+        running_vm(vm=rerun_on_failure_vm)
+        LOGGER.info(f"VM {rerun_on_failure_vm.name} is running and SSH accessible after restore")
+
+
+class TestVmNotAutoStartedDuringRestore:
+    """
+    [NEGATIVE] Tests verifying VM does not auto-start during snapshot restore
+    with runStrategy: RerunOnFailure.
+
+    This validates the root cause fix for CNV-63819: virt-controller must not
+    attempt to start the VM while a restore operation is in progress.
+    """
+
+    @pytest.mark.polarion("CNV-63819")
+    def test_vm_not_auto_started_during_restore(
+        self,
+        admin_client,
+        rerun_on_failure_vm,
+        rerun_on_failure_vm_snapshot,
+    ):
+        """
+        [NEGATIVE] Test that VM does not auto-start during snapshot restore
+        with RerunOnFailure.
+
+        Steps:
+            1. Create VirtualMachineRestore from snapshot
+            2. Check for VirtualMachineInstance resources during restore
+
+        Expected:
+            - No VirtualMachineInstance exists during restore operation
+        """
+        with VirtualMachineRestore(
+            client=admin_client,
+            name=f"restore-negative-{rerun_on_failure_vm_snapshot.name}",
+            namespace=rerun_on_failure_vm.namespace,
+            vm_name=rerun_on_failure_vm.name,
+            snapshot_name=rerun_on_failure_vm_snapshot.name,
+        ) as vm_restore:
+            LOGGER.info(
+                f"Monitoring VMI existence during restore of {rerun_on_failure_vm.name}"
+            )
+            for sample in TimeoutSampler(
+                wait_timeout=TIMEOUT_5MIN,
+                sleep=TIMEOUT_5SEC,
+                func=lambda: vm_restore.instance.status.get("complete"),
+            ):
+                assert not rerun_on_failure_vm.vmi.exists, (
+                    f"VMI {rerun_on_failure_vm.name} was unexpectedly created during restore, "
+                    "indicating virt-controller attempted to start VM"
+                )
+                if sample:
+                    break
+            LOGGER.info(
+                f"Restore completed without VMI creation for {rerun_on_failure_vm.name}"
+            )
+
+
+class TestSnapshotRestoreRunStrategies:
+    """
+    Regression tests for snapshot restore across different run strategies.
+
+    Ensures the CNV-63819 fix does not break snapshot restore for other
+    run strategies.
+    """
+
+    @pytest.mark.parametrize(
+        "run_strategy_vm_for_restore",
+        [
+            pytest.param(
+                {"run_strategy": VirtualMachine.RunStrategy.ALWAYS},
+                marks=pytest.mark.polarion("CNV-63819"),
+                id="always",
+            ),
+            pytest.param(
+                {"run_strategy": VirtualMachine.RunStrategy.MANUAL},
+                marks=pytest.mark.polarion("CNV-63819"),
+                id="manual",
+            ),
+            pytest.param(
+                {"run_strategy": VirtualMachine.RunStrategy.HALTED},
+                marks=pytest.mark.polarion("CNV-63819"),
+                id="halted",
+            ),
+        ],
+        indirect=True,
+    )
+    def test_restore_completes(
+        self,
+        admin_client,
+        run_strategy_vm_for_restore,
+        run_strategy_vm_snapshot,
+    ):
+        """
+        Test that snapshot restore completes for VM with the given run strategy.
+
+        Steps:
+            1. Create VirtualMachineRestore from snapshot
+            2. Wait for restore to complete
+
+        Expected:
+            - VirtualMachineRestore status is "Complete"
+        """
+        with VirtualMachineRestore(
+            client=admin_client,
+            name=f"restore-{run_strategy_vm_snapshot.name}",
+            namespace=run_strategy_vm_for_restore.namespace,
+            vm_name=run_strategy_vm_for_restore.name,
+            snapshot_name=run_strategy_vm_snapshot.name,
+        ) as vm_restore:
+            vm_restore.wait_restore_done()
+            assert vm_restore.instance.status.get("complete"), (
+                f"VirtualMachineRestore {vm_restore.name} did not reach Complete status "
+                f"for run strategy {run_strategy_vm_for_restore.instance.spec.runStrategy}"
+            )
