+# -*- coding: utf-8 -*-
+
+"""
+VM Snapshot Restore Data Integrity Tests
+
+STP Reference: https://issues.redhat.com/browse/CNV-63819
+
+This module contains end-to-end tests verifying data integrity after snapshot
+restore for VMs with runStrategy: RerunOnFailure. Validates the complete
+snapshot/restore workflow including data written before and after the snapshot.
+"""
+
+import logging
+import shlex
+
+import pytest
+from ocp_resources.virtual_machine_restore import VirtualMachineRestore
+from pyhelper_utils.shell import run_ssh_commands
+
+LOGGER = logging.getLogger(__name__)
+
+pytestmark = pytest.mark.usefixtures(
+    "namespace",
+    "skip_if_no_storage_class_for_snapshot",
+)
+
+
+class TestSnapshotRestoreDataIntegrity:
+    """
+    Tests for data integrity after VM snapshot restore with runStrategy: RerunOnFailure.
+
+    Validates that pre-snapshot data is preserved and post-snapshot data is removed
+    after a restore operation completes.
+    """
+
+    @pytest.mark.polarion("CNV-63819")
+    def test_pre_snapshot_data_preserved(self, restored_data_integrity_vm):
+        """
+        Test that files created before a snapshot are preserved after restore.
+
+        Steps:
+            1. Read file original.txt from the restored VM
+
+        Expected:
+            - File content equals "data-before-snapshot"
+        """
+        output = run_ssh_commands(
+            host=restored_data_integrity_vm.ssh_exec,
+            commands=shlex.split(f"bash -c {shlex.quote('cat original.txt')}"),
+        )[0].strip()
+        assert output == "data-before-snapshot", (
+            f"Pre-snapshot file content mismatch: expected 'data-before-snapshot', got '{output}'"
+        )
+
+    @pytest.mark.polarion("CNV-63819")
+    def test_post_snapshot_data_removed(self, restored_data_integrity_vm):
+        """
+        Test that files created after a snapshot are removed after restore.
+
+        Steps:
+            1. Check if file after.txt exists on the restored VM
+
+        Expected:
+            - File after.txt does NOT exist
+        """
+        output = run_ssh_commands(
+            host=restored_data_integrity_vm.ssh_exec,
+            commands=shlex.split(
+                f"bash -c {shlex.quote('test -f after.txt && echo exists || echo not-exists')}"
+            ),
+        )[0].strip()
+        assert output == "not-exists", (
+            f"Post-snapshot file after.txt should not exist after restore, but got '{output}'"
+        )
+
+
+@pytest.mark.polarion("CNV-63819")
+def test_multiple_snapshot_restores_complete(
+    admin_client,
+    rerun_on_failure_vm,
+    multiple_rerun_on_failure_snapshots,
+):
+    """
+    Test that multiple snapshots can each be restored successfully.
+
+    Steps:
+        1. Create VirtualMachineRestore from first snapshot and wait for completion
+        2. Create VirtualMachineRestore from second snapshot and wait for completion
+
+    Expected:
+        - Both VirtualMachineRestore resources reach "Complete" status
+    """
+    for idx, snapshot in enumerate(multiple_rerun_on_failure_snapshots):
+        LOGGER.info(f"Restoring snapshot {idx + 1}: {snapshot.name}")
+        with VirtualMachineRestore(
+            client=admin_client,
+            name=f"restore-multi-{idx}-{snapshot.name}",
+            namespace=rerun_on_failure_vm.namespace,
+            vm_name=rerun_on_failure_vm.name,
+            snapshot_name=snapshot.name,
+        ) as vm_restore:
+            vm_restore.wait_restore_done()
+            assert vm_restore.instance.status.get("complete"), (
+                f"VirtualMachineRestore {vm_restore.name} for snapshot {snapshot.name} "
+                "did not reach Complete status"
+            )
+        LOGGER.info(f"Snapshot {idx + 1} restore completed successfully")
