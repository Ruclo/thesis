+        - run_strategy: [Always, Manual, Halted]
+
+    Markers:
+        - storage
+
+    Preconditions:
+        - Storage class with snapshot support available
+        - Running VM with parametrized runStrategy
+        - Snapshot created from the VM
+        - VM stopped
