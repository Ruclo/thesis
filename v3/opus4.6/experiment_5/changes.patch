+"""
+StorageProfile snapshotClass Honored for VM Snapshot Tests
+
+STP Reference: /home/fedora/thesis/stps/5.md
+Jira: https://issues.redhat.com/browse/CNV-61266
+
+This module contains tests verifying that VM snapshots honor the snapshotClass
+field defined in StorageProfile resources, rather than ignoring it and falling
+back to label-based VolumeSnapshotClass selection.
+"""
+
+import logging
+
+import pytest
+from ocp_resources.resource import ResourceEditor
+from ocp_resources.storage_class import StorageClass
+from ocp_resources.storage_profile import StorageProfile
+from ocp_resources.virtual_machine_cluster_instancetype import VirtualMachineClusterInstancetype
+from ocp_resources.virtual_machine_cluster_preference import VirtualMachineClusterPreference
+from ocp_resources.virtual_machine_restore import VirtualMachineRestore
+from ocp_resources.virtual_machine_snapshot import VirtualMachineSnapshot
+from ocp_resources.volume_snapshot import VolumeSnapshot
+from ocp_resources.volume_snapshot_class import VolumeSnapshotClass
+
+from utilities.constants import OS_FLAVOR_RHEL, RHEL10_PREFERENCE, U1_SMALL
+from utilities.storage import data_volume_template_with_source_ref_dict
+from utilities.virt import VirtualMachineForTests, running_vm
+
+LOGGER = logging.getLogger(__name__)
+
+pytestmark = [
+    pytest.mark.usefixtures("namespace", "skip_if_no_storage_class_for_snapshot"),
+    pytest.mark.storage,
+]
+
+
+@pytest.fixture(scope="module")
+def volume_snapshot_class_for_storage(admin_client, snapshot_storage_class_name_scope_module):
+    """VolumeSnapshotClass whose driver matches the storage class provisioner."""
+    storage_class = StorageClass(client=admin_client, name=snapshot_storage_class_name_scope_module)
+    provisioner = storage_class.instance.provisioner
+    for vsc in VolumeSnapshotClass.get(client=admin_client):
+        if vsc.instance.driver == provisioner:
+            LOGGER.info(f"Found VolumeSnapshotClass {vsc.name} matching provisioner {provisioner}")
+            return vsc
+    pytest.skip(f"No VolumeSnapshotClass found matching provisioner {provisioner}")
+
+
+@pytest.fixture()
+def storage_profile_with_snapshot_class(
+    snapshot_storage_class_name_scope_module,
+    volume_snapshot_class_for_storage,
+):
+    """StorageProfile temporarily configured with specific snapshotClass."""
+    storage_profile = StorageProfile(name=snapshot_storage_class_name_scope_module)
+    vsc_name = volume_snapshot_class_for_storage.name
+    LOGGER.info(f"Setting StorageProfile {storage_profile.name} snapshotClass to {vsc_name}")
+    with ResourceEditor(patches={storage_profile: {"spec": {"snapshotClass": vsc_name}}}):
+        yield vsc_name
+
+
+@pytest.fixture()
+def vm_for_snapshot_class_test(
+    admin_client,
+    namespace,
+    snapshot_storage_class_name_scope_module,
+    rhel10_data_source_scope_session,
+):
+    """Running VM on snapshot-capable storage for snapshotClass testing."""
+    with VirtualMachineForTests(
+        name="vm-cnv-61266",
+        namespace=namespace.name,
+        client=admin_client,
+        os_flavor=OS_FLAVOR_RHEL,
+        vm_instance_type=VirtualMachineClusterInstancetype(
+            client=admin_client,
+            name=U1_SMALL,
+        ),
+        vm_preference=VirtualMachineClusterPreference(
+            client=admin_client,
+            name=RHEL10_PREFERENCE,
+        ),
+        data_volume_template=data_volume_template_with_source_ref_dict(
+            data_source=rhel10_data_source_scope_session,
+            storage_class=snapshot_storage_class_name_scope_module,
+        ),
+    ) as vm:
+        running_vm(vm=vm)
+        yield vm
+
+
+@pytest.fixture()
+def vm_snapshot_with_profile_snapshot_class(
+    storage_profile_with_snapshot_class,
+    admin_client,
+    vm_for_snapshot_class_test,
+):
+    """VMSnapshot created after StorageProfile snapshotClass is configured.
+
+    Depends on storage_profile_with_snapshot_class to ensure the StorageProfile
+    is patched before the snapshot is created.
+    """
+    vm = vm_for_snapshot_class_test
+    with VirtualMachineSnapshot(
+        name=f"snapshot-{vm.name}",
+        namespace=vm.namespace,
+        vm_name=vm.name,
+        client=admin_client,
+    ) as snapshot:
+        snapshot.wait_snapshot_done()
+        LOGGER.info(f"VMSnapshot {snapshot.name} is ready")
+        yield snapshot
+
+
+@pytest.fixture()
+def vm_snapshot_default_profile(admin_client, vm_for_snapshot_class_test):
+    """VMSnapshot created with default StorageProfile (no snapshotClass configured)."""
+    vm = vm_for_snapshot_class_test
+    with VirtualMachineSnapshot(
+        name=f"snapshot-{vm.name}",
+        namespace=vm.namespace,
+        vm_name=vm.name,
+        client=admin_client,
+    ) as snapshot:
+        snapshot.wait_snapshot_done()
+        LOGGER.info(f"VMSnapshot {snapshot.name} is ready")
+        yield snapshot
+
+
+class TestStorageProfileSnapshotClassHonored:
+    """Tests for StorageProfile snapshotClass being honored during VM snapshot creation."""
+
+    @pytest.mark.polarion("CNV-61266")
+    def test_vm_snapshot_uses_storage_profile_snapshot_class(
+        self,
+        admin_client,
+        namespace,
+        storage_profile_with_snapshot_class,
+        vm_snapshot_with_profile_snapshot_class,
+    ):
+        """
+        Test that a VM snapshot uses the snapshotClass defined in StorageProfile.
+
+        Steps:
+            1. Create a VMSnapshot from the running VM
+            2. Wait for the VMSnapshot to reach ready state
+            3. Retrieve the VolumeSnapshot created by the VMSnapshot
+            4. Read the volumeSnapshotClassName from the VolumeSnapshot spec
+
+        Expected:
+            - VolumeSnapshot's volumeSnapshotClassName equals the snapshotClass
+              configured in StorageProfile
+        """
+        expected_vsc_name = storage_profile_with_snapshot_class
+        volume_snapshots = list(VolumeSnapshot.get(namespace=namespace.name, client=admin_client))
+        assert volume_snapshots, "No VolumeSnapshots found after VMSnapshot creation"
+        for volume_snapshot in volume_snapshots:
+            actual_vsc_name = volume_snapshot.instance.spec.volumeSnapshotClassName
+            LOGGER.info(
+                f"VolumeSnapshot {volume_snapshot.name} uses VolumeSnapshotClass: {actual_vsc_name}"
+            )
+            assert actual_vsc_name == expected_vsc_name, (
+                f"VolumeSnapshot {volume_snapshot.name} uses VolumeSnapshotClass "
+                f"'{actual_vsc_name}' instead of expected '{expected_vsc_name}' from StorageProfile"
+            )
+
+    @pytest.mark.polarion("CNV-61266")
+    def test_vm_restore_succeeds_with_storage_profile_snapshot_class(
+        self,
+        admin_client,
+        storage_profile_with_snapshot_class,
+        vm_for_snapshot_class_test,
+        vm_snapshot_with_profile_snapshot_class,
+    ):
+        """
+        Test that a VM can be restored from a snapshot created with StorageProfile snapshotClass.
+
+        Steps:
+            1. Stop the VM
+            2. Restore the VM from the snapshot
+            3. Start the VM and wait for it to become running
+
+        Expected:
+            - VM is "Running" and SSH accessible after restore
+        """
+        vm = vm_for_snapshot_class_test
+        snapshot = vm_snapshot_with_profile_snapshot_class
+        vm.stop(wait=True)
+        LOGGER.info(f"VM {vm.name} stopped, restoring from snapshot {snapshot.name}")
+        with VirtualMachineRestore(
+            name=f"restore-{snapshot.name}",
+            namespace=vm.namespace,
+            vm_name=vm.name,
+            snapshot_name=snapshot.name,
+            client=admin_client,
+        ) as restore:
+            restore.wait_restore_done()
+            LOGGER.info(f"Restore {restore.name} completed")
+        running_vm(vm=vm)
+        LOGGER.info(f"VM {vm.name} is running and SSH accessible after restore")
+
+
+class TestStorageProfileSnapshotClassFallback:
+    """Tests for fallback behavior when StorageProfile has no snapshotClass set."""
+
+    @pytest.mark.polarion("CNV-61266")
+    def test_vm_snapshot_falls_back_to_driver_based_selection(
+        self,
+        admin_client,
+        namespace,
+        volume_snapshot_class_for_storage,
+        vm_snapshot_default_profile,
+    ):
+        """
+        Test that VM snapshot falls back to driver-based VolumeSnapshotClass selection
+        when StorageProfile has no snapshotClass configured.
+
+        Steps:
+            1. Create a VMSnapshot from the running VM
+            2. Wait for the VMSnapshot to reach ready state
+            3. Retrieve the VolumeSnapshot created by the VMSnapshot
+            4. Read the volumeSnapshotClassName from the VolumeSnapshot spec
+            5. Identify the VolumeSnapshotClass whose driver matches the storage class provisioner
+
+        Expected:
+            - VolumeSnapshot's volumeSnapshotClassName equals the driver-matched
+              VolumeSnapshotClass name
+        """
+        expected_vsc_name = volume_snapshot_class_for_storage.name
+        volume_snapshots = list(VolumeSnapshot.get(namespace=namespace.name, client=admin_client))
+        assert volume_snapshots, "No VolumeSnapshots found after VMSnapshot creation"
+        for volume_snapshot in volume_snapshots:
+            actual_vsc_name = volume_snapshot.instance.spec.volumeSnapshotClassName
+            LOGGER.info(
+                f"VolumeSnapshot {volume_snapshot.name} uses VolumeSnapshotClass: {actual_vsc_name}"
+            )
+            assert actual_vsc_name == expected_vsc_name, (
+                f"VolumeSnapshot {volume_snapshot.name} uses VolumeSnapshotClass "
+                f"'{actual_vsc_name}' instead of expected driver-matched '{expected_vsc_name}'"
+            )
