+This module contains tests for the commonInstancetypesDeployment field in the
+HyperConverged CR spec, which controls whether common VirtualMachineClusterInstancetype
+and VirtualMachineClusterPreference resources are deployed by the operator.
+"""
+
+import logging
+
+import pytest
+from ocp_resources.resource import Resource
+from ocp_resources.virtual_machine_cluster_instancetype import (
+    VirtualMachineClusterInstancetype,
+)
+from ocp_resources.virtual_machine_cluster_preference import (
+    VirtualMachineClusterPreference,
+)
+from timeout_sampler import TimeoutSampler
+
+from utilities.constants import TIMEOUT_2MIN
+
+LOGGER = logging.getLogger(__name__)
+
+COMMON_INSTANCETYPE_VENDOR_LABEL = f"{Resource.ApiGroup.INSTANCETYPE_KUBEVIRT_IO}/vendor=redhat.com"
+
+pytestmark = [pytest.mark.gating, pytest.mark.arm64, pytest.mark.s390x]
+
+
+class TestCommonInstancetypesDeployment:
+    """
+    Tests for common instancetypes deployment configuration via HCO CR.
+
+    Preconditions:
+        - OpenShift Virtualization installed and HCO CR accessible
+        - HCO version supports commonInstancetypesDeployment field
+    """
+
+    @pytest.mark.polarion("CNV-61256")
+    def test_common_instancetypes_deployed_by_default(self, admin_client):
+        """
+        Test that common instancetype resources are deployed by default.
+
+        Steps:
+            1. Query VirtualMachineClusterInstancetype resources with vendor label
+               "redhat.com"
+
+        Expected:
+            - VirtualMachineClusterInstancetype resources with vendor label
+              "redhat.com" exist
+        """
+        LOGGER.info("Querying VirtualMachineClusterInstancetype resources with vendor label")
+        common_instancetypes = list(
+            VirtualMachineClusterInstancetype.get(
+                client=admin_client,
+                label_selector=COMMON_INSTANCETYPE_VENDOR_LABEL,
+            )
+        )
+        assert common_instancetypes, (
+            "No common VirtualMachineClusterInstancetype resources found with label "
+            f"'{COMMON_INSTANCETYPE_VENDOR_LABEL}', expected resources to be deployed by default"
+        )
+
+    @pytest.mark.polarion("CNV-61256")
+    def test_common_preferences_deployed_by_default(self, admin_client):
+        """
+        Test that common preference resources are deployed by default.
+
+        Steps:
+            1. Query VirtualMachineClusterPreference resources with vendor label
+               "redhat.com"
+
+        Expected:
+            - VirtualMachineClusterPreference resources with vendor label
