+    @pytest.mark.polarion("CNV-61256")
+    @pytest.mark.usefixtures("disabled_common_instancetypes_deployment_after_reconcile")
+    def test_disabled_setting_persists_after_reconciliation(self, admin_client):
+        """
+        Test that the Disabled setting persists after HCO reconciliation is
+        triggered by an unrelated spec change.
+
+        Preconditions:
+            - HCO CR commonInstancetypesDeployment set to Disabled
+            - HCO reconciliation completed
+            - Common instancetype resources confirmed removed
+
+        Steps:
+            1. Trigger HCO reconciliation by modifying an unrelated HCO spec field
+            2. Wait for HCO reconciliation to complete
+            3. Query VirtualMachineClusterInstancetype resources with vendor label
+               "redhat.com"
+
+        Expected:
+            - VirtualMachineClusterInstancetype resources with vendor label
+              "redhat.com" do NOT exist
