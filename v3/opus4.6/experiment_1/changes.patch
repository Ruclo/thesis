+import logging
+
+import pytest
+
+from utilities.hco import ResourceEditorValidateHCOReconcile
+
+LOGGER = logging.getLogger(__name__)
+
+COMMON_INSTANCETYPES_DEPLOYMENT_SPEC_KEY = "CommonInstancetypesDeployment"
+DEPLOYMENT_DISABLED = {"enabled": False}
+DEPLOYMENT_ENABLED = {"enabled": True}
+RECONCILE_TRIGGER_ANNOTATION_KEY = "test.cnv.io/reconcile-trigger"
+
+
+@pytest.fixture()
+def disabled_common_instancetypes_deployment(
+    admin_client,
+    hco_namespace,
+    hyperconverged_resource_scope_function,
+):
+    """HCO CR with CommonInstancetypesDeployment.enabled set to false."""
+    LOGGER.info("Setting CommonInstancetypesDeployment.enabled to false in HCO CR")
+    with ResourceEditorValidateHCOReconcile(
+        patches={
+            hyperconverged_resource_scope_function: {
+                "spec": {COMMON_INSTANCETYPES_DEPLOYMENT_SPEC_KEY: DEPLOYMENT_DISABLED}
+            }
+        },
+        wait_for_reconcile_post_update=True,
+        admin_client=admin_client,
+        hco_namespace=hco_namespace.name,
+    ):
+        yield
+
+
+@pytest.fixture()
+def reenabled_common_instancetypes_deployment(
+    admin_client,
+    hco_namespace,
+    hyperconverged_resource_scope_function,
+):
+    """HCO CR with CommonInstancetypesDeployment toggled from disabled to enabled."""
+    LOGGER.info("Setting CommonInstancetypesDeployment.enabled to false before re-enabling")
+    disabled_editor = ResourceEditorValidateHCOReconcile(
+        patches={
+            hyperconverged_resource_scope_function: {
+                "spec": {COMMON_INSTANCETYPES_DEPLOYMENT_SPEC_KEY: DEPLOYMENT_DISABLED}
+            }
+        },
+        wait_for_reconcile_post_update=True,
+        admin_client=admin_client,
+        hco_namespace=hco_namespace.name,
+    )
+    disabled_editor.update(backup_resources=True)
+
+    LOGGER.info("Setting CommonInstancetypesDeployment.enabled to true in HCO CR")
+    enabled_editor = ResourceEditorValidateHCOReconcile(
+        patches={
+            hyperconverged_resource_scope_function: {
+                "spec": {COMMON_INSTANCETYPES_DEPLOYMENT_SPEC_KEY: DEPLOYMENT_ENABLED}
+            }
+        },
+        wait_for_reconcile_post_update=True,
+        admin_client=admin_client,
+        hco_namespace=hco_namespace.name,
+    )
+    enabled_editor.update(backup_resources=True)
+
+    yield
+
+    LOGGER.info("Restoring HCO CR to original state")
+    enabled_editor.restore()
+    disabled_editor.restore()
+
+
+@pytest.fixture()
+def disabled_common_instancetypes_deployment_after_reconcile(
+    admin_client,
