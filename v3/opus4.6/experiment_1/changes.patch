+        """
+        LOGGER.info("Querying VirtualMachineClusterPreference resources with vendor label")
+        common_preferences = list(
+            VirtualMachineClusterPreference.get(
+                client=admin_client,
+                label_selector=COMMON_INSTANCETYPE_VENDOR_LABEL,
+            )
+        )
+        assert common_preferences, (
+            "No common VirtualMachineClusterPreference resources found with label "
+            f"'{COMMON_INSTANCETYPE_VENDOR_LABEL}', expected resources to be deployed by default"
+        )
+
+    @pytest.mark.polarion("CNV-61256")
+    @pytest.mark.usefixtures("disabled_common_instancetypes_deployment")
+    def test_disable_common_instancetypes_removes_instancetype_resources(self, admin_client):
+        """
+        Test that setting commonInstancetypesDeployment to Disabled removes
+        common instancetype resources.
+
+        Preconditions:
+            - HCO CR commonInstancetypesDeployment set to Disabled
+            - HCO reconciliation completed
+
+        Steps:
+            1. Query VirtualMachineClusterInstancetype resources with vendor label
+               "redhat.com"
+
+        Expected:
+            - VirtualMachineClusterInstancetype resources with vendor label
+              "redhat.com" do NOT exist
+        """
+        LOGGER.info("Waiting for VirtualMachineClusterInstancetype resources to be removed after disabling")
+        for sample in TimeoutSampler(
+            wait_timeout=TIMEOUT_2MIN,
+            sleep=5,
+            func=lambda: list(
+                VirtualMachineClusterInstancetype.get(
+                    client=admin_client,
+                    label_selector=COMMON_INSTANCETYPE_VENDOR_LABEL,
+                )
+            ),
+        ):
+            if not sample:
+                break
+
