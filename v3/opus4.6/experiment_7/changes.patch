+"""
+Windows Guest Agent OS/Hostname Info Display Tests
+
+STP Reference: stps/7.md
+Jira: CNV-61262, CNV-56888
+
+This module contains tests verifying that Windows VM OS version and hostname
+information are correctly reported via the QEMU guest agent and displayed
+in VMI status. Addresses a race condition where domain.Status.OSInfo was
+sometimes empty despite the guest agent running.
+"""
+
+import logging
+
+import pytest
+
+from tests.virt.guest_agent.conftest import START_GUEST_AGENT_CMD
+from utilities.constants import OS_FLAVOR_WINDOWS, TIMEOUT_5MIN
+from utilities.ssp import get_windows_os_info, validate_os_info_vmi_vs_windows_os
+from utilities.virt import (
+    get_virtctl_os_info,
+    run_os_command,
+    validate_virtctl_guest_agent_after_guest_reboot,
+)
+
+pytestmark = [pytest.mark.high_resource_vm, pytest.mark.tier3]
+
+LOGGER = logging.getLogger(__name__)
+
+
+class TestWindowsGuestAgentOSInfo:
+    """
+    Tests for Windows VM guest agent OS and hostname information display.
+
+    Preconditions:
+        - Running Windows VM with qemu-guest-agent installed and running
+        - VM is SSH accessible
+    """
