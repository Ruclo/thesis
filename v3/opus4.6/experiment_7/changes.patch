+"""Conftest for Windows guest agent tests."""
+
+import logging
+
+import pytest
+
+from tests.os_params import WINDOWS_LATEST
+from tests.virt.cluster.common_templates.utils import get_matrix_os_golden_image_data_source
+from tests.virt.utils import (
+    get_data_volume_template_dict_with_default_storage_class,
+    get_or_create_golden_image_data_source,
+)
+from ocp_resources.template import Template
+from utilities.constants import TIMEOUT_2MIN, TIMEOUT_5MIN, TIMEOUT_30MIN
+from utilities.virt import (
+    VirtualMachineForTestsFromTemplate,
+    run_os_command,
+    running_vm,
+    wait_for_user_agent_down,
+)
+
+LOGGER = logging.getLogger(__name__)
+
+STOP_GUEST_AGENT_CMD = "powershell -command \"Stop-Service -Name 'QEMU-GA'\""
+START_GUEST_AGENT_CMD = "powershell -command \"Start-Service -Name 'QEMU-GA'\""
+
+
+@pytest.fixture(scope="class")
+def windows_golden_image_data_source(admin_client, golden_images_namespace):
+    """DataSource for the latest Windows golden image."""
+    yield from get_or_create_golden_image_data_source(
+        admin_client=admin_client,
+        golden_images_namespace=golden_images_namespace,
+        os_dict=WINDOWS_LATEST,
+    )
+
+
+@pytest.fixture(scope="class")
+def running_latest_windows_vm(
+    unprivileged_client,
+    namespace,
+    windows_golden_image_data_source,
+    modern_cpu_for_migration,
+):
+    """Running Windows VM with guest agent installed and SSH accessible."""
+    with VirtualMachineForTestsFromTemplate(
+        name="win-latest-ga-test",
+        namespace=namespace.name,
+        client=unprivileged_client,
+        labels=Template.generate_template_labels(**WINDOWS_LATEST["template_labels"]),
+        data_source=windows_golden_image_data_source,
+        data_volume_template=get_data_volume_template_dict_with_default_storage_class(
+            data_source=windows_golden_image_data_source
+        ),
+        cpu_model=modern_cpu_for_migration,
+    ) as vm:
+        running_vm(vm=vm, ssh_timeout=TIMEOUT_30MIN)
+        yield vm
+
+
+@pytest.fixture()
+def stopped_guest_agent_service(running_latest_windows_vm):
+    """Windows VM with guest agent service stopped; restarts agent on cleanup."""
+    vm = running_latest_windows_vm
+    LOGGER.info(f"Stopping guest agent service on {vm.name}")
+    run_os_command(vm=vm, command=STOP_GUEST_AGENT_CMD)
+    wait_for_user_agent_down(vm=vm, timeout=TIMEOUT_2MIN)
+    yield vm
+    LOGGER.info(f"Restarting guest agent service on {vm.name}")
+    run_os_command(vm=vm, command=START_GUEST_AGENT_CMD)
+    vm.wait_for_agent_connected(timeout=TIMEOUT_5MIN)
+
+
+# Multi-version fixtures
+@pytest.fixture(scope="class")
+def multi_version_windows_golden_image_data_source(
+    admin_client,
+    golden_images_namespace,
+    windows_os_matrix__class__,
+):
+    """DataSource for the parametrized Windows version golden image."""
+    yield from get_matrix_os_golden_image_data_source(
+        admin_client=admin_client,
+        golden_images_namespace=golden_images_namespace,
+        os_matrix=windows_os_matrix__class__,
+    )
+
+
+@pytest.fixture(scope="class")
+def running_multi_version_windows_vm(
+    unprivileged_client,
+    namespace,
+    windows_os_matrix__class__,
+    multi_version_windows_golden_image_data_source,
+    modern_cpu_for_migration,
+):
+    """Running Windows VM of parametrized version with guest agent and SSH."""
+    os_matrix_key = [*windows_os_matrix__class__][0]
+    with VirtualMachineForTestsFromTemplate(
+        name=os_matrix_key,
+        namespace=namespace.name,
+        client=unprivileged_client,
+        labels=Template.generate_template_labels(
+            **windows_os_matrix__class__[os_matrix_key]["template_labels"]
+        ),
+        data_source=multi_version_windows_golden_image_data_source,
+        data_volume_template=get_data_volume_template_dict_with_default_storage_class(
+            data_source=multi_version_windows_golden_image_data_source
+        ),
+        cpu_model=modern_cpu_for_migration,
+    ) as vm:
+        running_vm(vm=vm, ssh_timeout=TIMEOUT_30MIN)
+        yield vm
