+"""
+Windows Guest Agent OS/Hostname Info Display Tests
+
+STP Reference: stps/7.md
+Jira: CNV-61262 / CNV-56888
+
+Verifies that Windows VMs correctly display OS and hostname information
+via the guest agent, addressing the bug where domain.Status.OSInfo was
+sometimes empty despite the agent running.
+"""
+
+import logging
+
+import pytest
+
+from utilities.constants import OS_FLAVOR_WINDOWS, TIMEOUT_2MIN
+from utilities.ssp import get_windows_os_info, validate_os_info_vmi_vs_windows_os
+from utilities.virt import (
+    get_guest_os_info,
+    get_virtctl_os_info,
+    run_os_command,
+    running_vm,
+    validate_virtctl_guest_agent_after_guest_reboot,
+    validate_virtctl_guest_agent_data_over_time,
+    wait_for_user_agent_down,
+)
+
+pytestmark = [pytest.mark.virt, pytest.mark.high_resource_vm]
+
+LOGGER = logging.getLogger(__name__)
+TESTS_CLASS_NAME = "TestWindowsGuestAgentOSInfo"
+STOP_QEMU_GA_CMD = "powershell -command \"Stop-Service -Name 'QEMU-GA'\""
+START_QEMU_GA_CMD = "powershell -command \"Start-Service -Name 'QEMU-GA'\""
+
+
+class TestWindowsGuestAgentOSInfo:
+    @pytest.mark.sno
+    @pytest.mark.dependency(name=f"{TESTS_CLASS_NAME}::create_vm")
+    @pytest.mark.polarion("CNV-61262")
+    def test_create_vm(self, windows_ga_vm):
+        """Test Windows VM creation for guest agent OS info tests."""
+        # VM lifecycle: create is required before any other test can run
+        LOGGER.info("Create Windows VM for guest agent OS info tests.")
+        windows_ga_vm.create(wait=True)
+
+    @pytest.mark.sno
+    @pytest.mark.dependency(
+        name=f"{TESTS_CLASS_NAME}::start_vm",
+        depends=[f"{TESTS_CLASS_NAME}::create_vm"],
+    )
+    @pytest.mark.polarion("CNV-61262")
+    def test_start_vm(self, windows_ga_vm):
+        """Test Windows VM start and SSH accessibility."""
+        # VM lifecycle: start is required before guest agent tests
+        LOGGER.info("Start Windows VM and wait for SSH accessibility.")
+        running_vm(vm=windows_ga_vm)
+
+    @pytest.mark.sno
+    @pytest.mark.dependency(
+        name=f"{TESTS_CLASS_NAME}::vmi_os_info",
+        depends=[f"{TESTS_CLASS_NAME}::start_vm"],
+    )
+    @pytest.mark.polarion("CNV-61262")
+    def test_vmi_os_info_matches_windows_os(self, windows_ga_vm):
+        """Test that VMI guestOSInfo matches the actual Windows OS information.
+
+        Steps:
+            1. Compare VMI status guestOSInfo fields against OS information
+               queried directly from the Windows guest via SSH
+
+        Expected:
+            - VMI guestOSInfo fields match the values reported by the Windows guest OS
+        """
+        validate_os_info_vmi_vs_windows_os(vm=windows_ga_vm)
+
+    @pytest.mark.sno
+    @pytest.mark.dependency(depends=[f"{TESTS_CLASS_NAME}::start_vm"])
+    @pytest.mark.polarion("CNV-61262")
+    def test_vmi_hostname_matches_windows_hostname(self, windows_ga_vm):
+        """Test that VMI guest agent reports the correct Windows hostname.
+
+        Steps:
+            1. Retrieve the hostname from the Windows guest via SSH
+            2. Retrieve the hostname from virtctl guestosinfo
+
+        Expected:
+            - VMI reported hostname equals the hostname obtained from the Windows guest
+        """
+        virtctl_info = get_virtctl_os_info(vm=windows_ga_vm)
+        assert virtctl_info, "Failed to get guest OS info via virtctl"
+        windows_hostname = get_windows_os_info(ssh_exec=windows_ga_vm.ssh_exec)["hostname"]
+        assert virtctl_info["hostname"] == windows_hostname, (
+            f"Hostname mismatch: virtctl reports '{virtctl_info['hostname']}', "
+            f"Windows reports '{windows_hostname}'"
+        )
+
+    @pytest.mark.sno
+    @pytest.mark.dependency(depends=[f"{TESTS_CLASS_NAME}::start_vm"])
+    @pytest.mark.polarion("CNV-61262")
+    def test_vmi_os_info_not_empty(self, windows_ga_vm):
+        """Test that VMI guestOSInfo is consistently populated when guest agent is running.
+
+        Steps:
+            1. Poll VMI status guestOSInfo over time to verify data is stable
+
+        Expected:
+            - guestOSInfo is consistently available and not intermittently empty
+        """
+        assert validate_virtctl_guest_agent_data_over_time(vm=windows_ga_vm), (
+            "Guest agent OS info is not consistently available over time"
+        )
+
+    @pytest.mark.polarion("CNV-61262")
+    @pytest.mark.dependency(
+        name=f"{TESTS_CLASS_NAME}::reboot",
+        depends=[f"{TESTS_CLASS_NAME}::vmi_os_info"],
+    )
+    def test_guest_agent_info_available_after_reboot(self, windows_ga_vm):
+        """Test that guest agent OS information is available after a guest reboot.
+
+        Steps:
+            1. Perform a guest-initiated reboot of the Windows VM
+            2. Wait for the VM to become running and SSH accessible
+            3. Validate guest agent data is consistently available
+
+        Expected:
+            - Guest agent data is available and responds consistently over time after the reboot
+        """
+        validate_virtctl_guest_agent_after_guest_reboot(
+            vm=windows_ga_vm, os_type=OS_FLAVOR_WINDOWS
+        )
+
+    @pytest.mark.tier3
+    @pytest.mark.polarion("CNV-61262")
+    @pytest.mark.dependency(
+        name=f"{TESTS_CLASS_NAME}::agent_stopped",
+        depends=[f"{TESTS_CLASS_NAME}::reboot"],
+    )
+    def test_os_info_absent_when_agent_stopped(self, windows_ga_vm):
+        """[NEGATIVE] Test that agent is detected as disconnected when the service is stopped.
+
+        Steps:
+            1. Stop the qemu-ga Windows service inside the guest
+            2. Wait for AgentConnected condition to become False
+
+        Expected:
+            - AgentConnected condition is not True after the agent service stops
+        """
+        # Dependency on reboot test: ensures agent is running before we stop it
+        LOGGER.info("Stopping QEMU-GA service on Windows guest.")
+        run_os_command(vm=windows_ga_vm, command=STOP_QEMU_GA_CMD)
+        wait_for_user_agent_down(vm=windows_ga_vm, timeout=TIMEOUT_2MIN)
+
+    @pytest.mark.tier3
+    @pytest.mark.polarion("CNV-61262")
+    @pytest.mark.dependency(depends=[f"{TESTS_CLASS_NAME}::agent_stopped"])
+    def test_os_info_appears_when_agent_starts(self, windows_ga_vm):
+        """Test that OS info appears in VMI status when the agent service is started.
+
+        Steps:
+            1. Start the qemu-ga Windows service inside the guest
+            2. Wait for VMI status guestOSInfo to become populated
+
+        Expected:
+            - guestOSInfo contains a non-empty "id" field after the agent service starts
+        """
+        # Dependency on agent_stopped: agent was stopped by previous test
+        LOGGER.info("Starting QEMU-GA service on Windows guest.")
+        run_os_command(vm=windows_ga_vm, command=START_QEMU_GA_CMD)
+        guest_os_info = get_guest_os_info(vmi=windows_ga_vm.vmi)
+        assert guest_os_info, "guestOSInfo not available after agent start"
+        assert guest_os_info["id"], (
+            f"guestOSInfo 'id' field is empty after agent start: {guest_os_info}"
+        )
+
+    @pytest.mark.sno
+    @pytest.mark.dependency(depends=[f"{TESTS_CLASS_NAME}::create_vm"])
+    @pytest.mark.polarion("CNV-61262")
+    def test_vm_deletion(self, windows_ga_vm):
+        """Test Windows VM deletion."""
+        LOGGER.info("Delete Windows VM.")
+        windows_ga_vm.delete(wait=True)
